{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/rezerv/(auth.js|sw.js|pwa.js|index.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/info", "destination": "/info.html" },
    { "source": "/secret", "destination": "/secret.html" },
    { "source": "/rezerv", "destination": "/rezerv/index.html" },
    { "source": "/rezerv/secret", "destination": "/rezerv/secret.html" },
    { "source": "/rezerv/admin/admin", "destination": "/rezerv/admin/admin.html" },
    { "source": "/admin/admin", "destination": "/admin/admin.html" }
  ]
}
